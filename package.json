{
  "name": "11e-template-builder",
  "version": "2.0.0",
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:mpf && tsc && vite build",
    "build:mpf": "node --experimental-strip-types scripts/buildMpfData.ts",
    "preview": "vite preview",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --silent",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch --silent",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage --silent",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' jest --ci --coverage --reporters=default --reporters=jest-junit --silent"
  },
  "devDependencies": {
    "@interactjs/types": "^1.10.27",
    "@tailwindcss/vite": "^4.3.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/sortablejs": "^1.15.9",
    "autoprefixer": "^10.5.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^17.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "dependencies": {
    "html2canvas-pro": "^2.2.0",
    "interactjs": "^1.10.27",
    "sortablejs": "^1.15.7"
  }
}
